#!/usr/bin/env bash
# WORKLOG-SPEC section 8.2 + section 14.
# Install: git config core.hooksPath hooks
set -euo pipefail

fail() { echo "worklog: $*" >&2; exit 1; }

for f in .work/todo.jsonl .work/done.jsonl; do
  [ -f "$f" ] || continue

  # The trailing-newline invariant. Without it, union merge fuses the last line
  # of one side with the first line of the other and you lose two events to one
  # unparseable line. This check is the whole reason this hook exists.
  [ -z "$(tail -c1 "$f")" ] || fail "$f has no trailing newline (invariant 15.1)"

  python3 - "$f" <<'PY' || fail "schema validation failed"
import json, sys
ok = True
for n, line in enumerate(open(sys.argv[1]), 1):
    if not line.strip():
        continue
    try:
        ev = json.loads(line)
    except json.JSONDecodeError as e:
        print(f"  {sys.argv[1]}:{n}: unparseable: {e}"); ok = False; continue
    for field in ("ev", "ts", "actor", "op"):
        if field not in ev:
            print(f"  {sys.argv[1]}:{n}: missing {field}"); ok = False
    if ev.get("op") != "compact" and "item" not in ev:
        print(f"  {sys.argv[1]}:{n}: missing item"); ok = False
    # Taxonomy rules (spec §3.3 / taxonomy §2) on new-style create events.
    # Legacy `type` events predate the split and are normalized by the fold.
    if ev.get("op") in ("create", "snapshot"):
        s = ev.get("set") or {}
        lvl, knd = s.get("level"), s.get("kind")
        if lvl is not None and lvl not in ("epic", "story", "task", "subtask"):
            print(f"  {sys.argv[1]}:{n}: unknown level {lvl!r}"); ok = False
        if knd is not None and knd not in ("feature", "bug", "ops", "triage"):
            print(f"  {sys.argv[1]}:{n}: unknown kind {knd!r}"); ok = False
        if lvl == "epic" and knd in ("bug", "triage"):
            print(f"  {sys.argv[1]}:{n}: level:epic with kind:{knd} — "
                  "epics are feature or ops (taxonomy 2.2)"); ok = False
        if lvl == "epic" and s.get("milestone"):
            print(f"  {sys.argv[1]}:{n}: milestone on an epic — "
                  "milestone lives on leaves (taxonomy 2.5)"); ok = False
sys.exit(0 if ok else 1)
PY
done

# Invariant 15.7: the roadmap is generated. Regenerate and diff.
# mktemp, not a fixed path: two checkouts running this concurrently must not
# race on the same scratch file.
if [ -f bin/render_roadmap.py ] && [ -f docs/roadmap.md ]; then
  tmp=$(mktemp)
  python3 bin/render_roadmap.py > "$tmp"
  if ! diff -q "$tmp" docs/roadmap.md >/dev/null; then
    rm -f "$tmp"
    fail "docs/roadmap.md is stale or hand-edited. Run: worklog roadmap-render"
  fi
  rm -f "$tmp"
fi

# Guarded: scaffolded repos have no tests/ (the suite lives in the source repo).
[ ! -f tests/test_fold.py ] || python3 tests/test_fold.py -q >/dev/null 2>&1 || fail "fold tests failing"

# ADRs: schema + cross-file invariants. Guarded like the fold tests.
[ ! -d docs/adr ] || [ ! -x bin/worklog ] || python3 bin/worklog adr check >/dev/null || fail "ADR validation failed — run: worklog adr check"
