#!/usr/bin/env python3
"""
worklog -- CLI entry point. WORKLOG-SPEC section 12.

Implemented: add, update, close, link, show, list, fold, plan-capture,
             roadmap-render, roadmap-snapshot, wiki-add, compact,
             status (daily|weekly|timecard),
             ingest, conflict, resolve (pull side, sections 10.2 and 10.6),
             sync (dispatcher: bin/sync_dispatch.py), adapter init|check,
             promote (classifier suggestion -> create event, taxonomy §6.4),
             adr new|list|check (docs/adr, bin/adr.py, schema/adr.schema.json).
No stubs remain.

Taxonomy (docs/plans/2026-07-18-work-taxonomy.md): items carry `level`
(epic|story|task|subtask), `kind` (feature|bug|ops|triage) and `milestone`
instead of the old single `type`. `--type` survives as a deprecated alias.
Write-time rules enforced here (§2): epics are feature/ops only; milestone
lives on leaves; a create without --kind deliberately omits kind so the fold
triages it (never silently `feature`).

Nothing else in the repo may write to .work/*.jsonl (invariant 15.4).
"""
import argparse, json, os, sys, time
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import ulid
from fold import (fold, FoldResult, read_lines, dedupe_and_sort,
                  OPEN_STATUSES, CLOSED_STATUSES, LEGACY_TYPE_MAP)

LOG = ".work/todo.jsonl"
PATHS = (".work/todo.jsonl", ".work/done.jsonl")
MAX_BODY = 2048  # derived from PIPE_BUF (section 8.3). Not a setting.
VERSION = "0.8.0"  # kept in step with plugin/.claude-plugin/plugin.json by tests/test_plugin.py


def append(event):
    """The only writer. Single O_APPEND write, always newline-terminated.

    Also self-heals a missing trailing newline on the existing file (a hand
    edit the hook hasn't caught yet): appending without the repair would fuse
    two events into one unparseable line and lose both (section 8.2).
    """
    if len(event.get("set", {}).get("body", "")) > MAX_BODY:
        sys.exit(f"worklog: body exceeds {MAX_BODY}B; put prose in the plan doc")
    line = json.dumps(event, separators=(",", ":"), sort_keys=True) + "\n"
    fd = os.open(LOG, os.O_WRONLY | os.O_APPEND | os.O_CREAT, 0o644)
    try:
        if os.fstat(fd).st_size:
            rfd = os.open(LOG, os.O_RDONLY)
            try:
                os.lseek(rfd, -1, os.SEEK_END)
                if os.read(rfd, 1) != b"\n":
                    line = "\n" + line
            finally:
                os.close(rfd)
        os.write(fd, line.encode())   # atomic under PIPE_BUF
    finally:
        os.close(fd)
    return event


def base(item, op, actor):
    return {"ev": ulid.new(), "ts": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "actor": actor, "item": item, "op": op}


LEVELS = ("epic", "story", "task", "subtask")
KINDS = ("feature", "bug", "ops", "triage")


def check_taxonomy(level, kind, milestone):
    """Write-time rules, taxonomy spec §2. The fold is lenient; this is not."""
    if level == "epic":
        if kind in ("bug", "triage"):
            sys.exit(f"worklog: an epic cannot be kind:{kind} — epics are "
                     "feature or ops (taxonomy §2.2)")
        if milestone is not None:
            sys.exit("worklog: milestone lives on leaves; epic milestones are "
                     "derived (taxonomy §2.5)")


def cmd_add(a):
    if a.unplanned and not a.discovered_during:
        sys.exit("worklog: --unplanned requires --discovered-during (section 5.4)")
    if a.legacy_type is not None:
        # Faithful legacy alias: same (level, kind) mapping the fold applies
        # to old `type` events (§3.2) — bug -> task/bug, the rest -> feature.
        print("worklog: --type is deprecated; use --level/--kind", file=sys.stderr)
        lvl, knd = LEGACY_TYPE_MAP[a.legacy_type]
        a.level, a.kind = lvl, a.kind or knd
    check_taxonomy(a.level, a.kind, a.milestone)
    item = ulid.new()
    ev = base(item, "create", a.actor)
    # kind is only written when given: an omitted kind folds to triage (§2.3),
    # never silently to feature.
    ev["set"] = {k: v for k, v in {
        "level": a.level, "kind": a.kind, "milestone": a.milestone,
        "title": a.title, "status": "todo", "priority": a.priority,
        "parent": a.parent, "plan": a.plan,
        "unplanned": True if a.unplanned else None,
        "discovered_during": a.discovered_during,
    }.items() if v is not None}
    if a.labels:
        ev["set"]["labels"] = a.labels.split(",")
    append(ev)
    print(item)


def _require_item(item):
    """Reject empty/whitespace item ids before any log write (worklog 01KXXMCG41)."""
    if not item or not item.strip():
        sys.exit("worklog: empty item id")


def cmd_update(a):
    _require_item(a.item)
    if a.kind is not None or a.milestone is not None:
        # §2 rules hold on update too, against the item's current level.
        cur = fold([LOG, ".work/done.jsonl"]).items.get(a.item, {})
        check_taxonomy(cur.get("level"), a.kind, a.milestone)
    ev = base(a.item, "update", a.actor)
    ev["set"] = {k: v for k, v in
                 {"status": a.status, "priority": a.priority, "title": a.title,
                  "kind": a.kind, "milestone": a.milestone}.items()
                 if v is not None}
    if a.add_label:
        ev["add"] = {"labels": a.add_label.split(",")}
    if a.del_label:
        ev["del"] = {"labels": a.del_label.split(",")}
    if not (ev.get("set") or ev.get("add") or ev.get("del")):
        sys.exit("worklog: nothing to update")
    append(ev)


def cmd_close(a):
    _require_item(a.item)
    ev = base(a.item, "close", a.actor)
    ev["set"] = {"status": a.status}
    if a.resolution:
        ev["set"]["resolution"] = a.resolution
    append(ev)


def cmd_link(a):
    _require_item(a.item)
    ev = base(a.item, "link", a.actor)
    ev["set"] = {"external": {k: v for k, v in {
        "system": a.system, "key": a.key, "url": a.url, "rev": a.rev,
        "hash": a.hash,
        "synced_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    }.items() if v is not None}}
    append(ev)


INGEST_FIELDS = ("title", "body", "status", "priority", "assignee", "type",
                 "level", "kind", "milestone")
STATUSES = OPEN_STATUSES + CLOSED_STATUSES
PRIORITIES = ("P0", "P1", "P2", "P3")


def cmd_ingest(a):
    """Ingest a remote change (section 10.2). `ev` is deterministic and `ts`
    is the REMOTE clock, so two devs polling the same change append
    byte-identical lines and the fold dedupes them to one."""
    _require_item(a.item)
    ev = {"ev": ulid.deterministic(a.system, a.key, a.rev, a.rev_ts_ms),
          "ts": _rfc3339(a.rev_ts_ms), "actor": a.system, "item": a.item,
          "op": "update",
          "src": {"system": a.system, "key": a.key, "rev": a.rev}}
    sets = {}
    for pair in a.set or []:
        field, eq, value = pair.partition("=")
        if not eq:
            sys.exit(f"worklog: bad --set {pair!r}; want field=value")
        if field not in INGEST_FIELDS:
            sys.exit(f"worklog: ingest cannot set {field!r} "
                     f"(allowed: {', '.join(INGEST_FIELDS)})")
        if field == "status" and value not in STATUSES:
            sys.exit(f"worklog: bad status {value!r}")
        if field == "priority" and value not in PRIORITIES:
            sys.exit(f"worklog: bad priority {value!r}")
        if field == "level" and value not in LEVELS:
            sys.exit(f"worklog: bad level {value!r}")
        if field == "kind" and value not in KINDS:
            sys.exit(f"worklog: bad kind {value!r}")
        sets[field] = value
    if sets:
        ev["set"] = sets
    if a.add_label:
        ev["add"] = {"labels": sorted(a.add_label.split(","))}
    if a.del_label:
        ev["del"] = {"labels": sorted(a.del_label.split(","))}
    if not (sets or a.add_label or a.del_label):
        sys.exit("worklog: nothing to ingest")
    append(ev)
    print(ev["ev"])


def cmd_conflict(a):
    """Record a both-sides-changed field (section 10.6). State never changes;
    the fold files it under _conflicts until a later write clears it."""
    _require_item(a.item)
    ev = base(a.item, "conflict", "sync")
    ev["set"] = {"field": a.field, "local": a.local, "remote": a.remote,
                 "remote_rev": a.remote_rev}
    append(ev)


def cmd_resolve(a):
    """Resolve the last open conflict on a field with a normal update event.
    The update outsorts the conflict, so the fold clears it (section 10.6)."""
    _require_item(a.item)
    r = fold([LOG, ".work/done.jsonl"])
    match = [i for k, i in r.items.items() if k.startswith(a.item)]
    if not match:
        sys.exit(f"worklog: no item matching {a.item}")
    item = match[0]
    open_c = [c for c in item.get("_conflicts", []) if c.get("field") == a.field]
    if not open_c:
        sys.exit(f"worklog: no open conflict on {a.field} for {a.item}")
    old = item.get(a.field)
    new = old if a.take == "local" else open_c[-1].get("remote")
    ev = base(item["id"], "update", a.actor)
    ev["set"] = {a.field: new}
    append(ev)
    print(f"{a.field}: {old} -> {new} (took {a.take})")


PUBLISHED = ".work/published.json"


def _register_published(key, file, title):
    """Register a file in the wiki publish set. published.json is a plain JSON
    map (spec 9.2), not an event log, so direct load/dump is allowed here."""
    published = {}
    if os.path.exists(PUBLISHED):
        with open(PUBLISHED, encoding="utf-8") as fh:
            published = json.load(fh)
    # Preserve url/rev/source_hash on re-register: wiping them would make the
    # next publish create a duplicate page (spec 9.2).
    entry = published.setdefault(key, {"url": None, "rev": None,
                                       "source_hash": None})
    entry["source"] = file
    entry["title"] = title
    os.makedirs(os.path.dirname(PUBLISHED), exist_ok=True)
    with open(PUBLISHED, "w", encoding="utf-8") as fh:
        json.dump(published, fh, indent=2, sort_keys=True)
        fh.write("\n")


def cmd_wiki_add(a):
    if not os.path.exists(a.file):
        sys.exit(f"worklog: {a.file} not found")
    _register_published(a.key, a.file, a.title)
    print(a.key)


def cmd_list(a):
    r = fold([LOG, ".work/done.jsonl"])
    items = r.open_items() if not a.all else list(r.items.values())
    for i in sorted(items, key=lambda x: (x.get("priority", "P9"), x["id"])):
        ext = i.get("external", {}).get("key", "-")
        print(f"{i['id'][:8]}  {i.get('priority','--'):3}  {i.get('status','?'):12} "
              f"{ext:10} {i.get('title','')}")
    if r.conflicts():
        print(f"\n{len(r.conflicts())} conflict(s) need attention: worklog show <id>",
              file=sys.stderr)


def cmd_show(a):
    _require_item(a.item)
    r = fold([LOG, ".work/done.jsonl"])
    match = [i for k, i in r.items.items() if k.startswith(a.item)]
    if not match:
        sys.exit(f"worklog: no item matching {a.item}")
    print(json.dumps(match[0], indent=2))


def cmd_fold(a):
    r = fold([LOG, ".work/done.jsonl"])
    print(json.dumps(sorted(r.items.values(), key=lambda i: i["id"]), indent=2))


def cmd_roadmap_render(a):
    import render_roadmap
    # --viz default matches render()'s default: the pre-commit hook diffs the
    # bare-script output against the file this writes.
    md = render_roadmap.render(viz="none" if a.no_viz else a.viz)
    os.makedirs("docs", exist_ok=True)
    with open("docs/roadmap.md", "w", encoding="utf-8") as fh:
        fh.write(md)
    print("docs/roadmap.md")


def cmd_roadmap_snapshot(a):
    import shutil
    if not os.path.exists("docs/roadmap.md"):
        sys.exit("worklog: docs/roadmap.md not found; run roadmap-render first")
    date = time.strftime("%Y-%m-%d", time.gmtime())
    name = f"{date}_{a.name}" if a.name else date
    path = f"docs/roadmap/{name}.md"
    if os.path.exists(path):
        sys.exit(f"worklog: {path} exists; snapshots are frozen "
                 "— pick a new --name")
    os.makedirs("docs/roadmap", exist_ok=True)
    shutil.copyfile("docs/roadmap.md", path)
    print(path)


def cmd_plan_capture(a):
    import plan_capture
    draft = open(a.file, encoding="utf-8").read() if a.file else sys.stdin.read()
    tasks = plan_capture.parse_tasks(draft)
    if not tasks:
        sys.exit("worklog: no '- [ ]' tasks found under a '## Tasks' heading")
    date = time.strftime("%Y-%m-%d", time.gmtime())
    path = f"docs/plans/{date}-{a.slug}.md"
    if os.path.exists(path):
        sys.exit(f"worklog: {path} exists; plans are never rewritten "
                 "(invariant 15.8) — pick a new slug to supersede")

    # Captured items get explicit kind:feature — a plan is deliberate feature
    # work, not a triage candidate (taxonomy §2.3 exemption by intent).
    epic_id = ulid.new()
    ev = base(epic_id, "create", a.actor)
    ev["set"] = {"level": "epic", "kind": "feature", "title": a.title,
                 "status": "todo", "priority": a.priority, "plan": path}
    append(ev)

    item_ids, last_task = [], epic_id
    for t in tasks:
        iid = ulid.new()
        ev = base(iid, "create", a.actor)
        ev["set"] = {"level": "subtask" if t["subtask"] else "task",
                     "kind": "feature",
                     "title": t["title"], "status": "todo",
                     "priority": t["priority"],
                     "parent": last_task if t["subtask"] else epic_id,
                     "plan": path}
        append(ev)
        item_ids.append(iid)
        if not t["subtask"]:
            last_task = iid

    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as fh:
        fh.write(plan_capture.front_matter(date, a.slug, a.title, epic_id, item_ids))
        fh.write(draft)
    print(path)
    print(epic_id)


SUGGESTIONS = ".work/suggestions.jsonl"


def cmd_promote(a):
    """Promote a classifier suggestion into exactly ONE create event
    (taxonomy spec §6.4). The suggestion is then marked consumed in
    suggestions.jsonl so the classifier gate dedupes against it."""
    try:
        fh = open(SUGGESTIONS, encoding="utf-8")
    except FileNotFoundError:
        sys.exit(f"worklog: {SUGGESTIONS} not found — no suggestions to "
                 "promote (the classifier writes it; see taxonomy spec §6)")
    records, consumed = {}, set()
    with fh:
        for line in fh:
            if not line.strip():
                continue
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                continue  # staging file is best-effort; skip bad lines
            sid = rec.get("suggestion_id")
            if rec.get("consumed"):
                consumed.add(sid)
            elif "proposed" in rec:
                records.setdefault(sid, rec)
    if a.suggestion_id in consumed:
        sys.exit(f"worklog: suggestion {a.suggestion_id} already consumed")
    if a.suggestion_id not in records:
        sys.exit(f"worklog: no suggestion {a.suggestion_id} in {SUGGESTIONS}")
    prop = records[a.suggestion_id].get("proposed") or {}
    level = prop.get("level", "task")
    kind = prop.get("kind")  # honored as proposed, including triage
    check_taxonomy(level, kind, prop.get("milestone"))
    item = ulid.new()
    ev = base(item, "create", a.actor)
    ev["set"] = {k: v for k, v in {
        "level": level, "kind": kind, "milestone": prop.get("milestone"),
        "title": prop.get("title"), "status": "todo",
        "parent": prop.get("parent"),
    }.items() if v is not None}
    append(ev)
    with open(SUGGESTIONS, "a", encoding="utf-8") as out:
        out.write(json.dumps({"consumed": True,
                              "suggestion_id": a.suggestion_id,
                              "item": item},
                             separators=(",", ":"), sort_keys=True) + "\n")
    print(item)


def cmd_adr_new(a):
    """Scaffold docs/adr/NNNN-slug.md and register it for wiki publish.
    ADR bodies are written once (Nygard); --supersedes N performs the one
    sanctioned mutation on ADR N: status + superseded_by only."""
    import re
    import adr
    ids = {}
    for path in adr.adr_files():
        m = re.match(r"(\d{4})-", os.path.basename(path))
        if m:
            ids[int(m.group(1))] = path
    nid = max(ids) + 1 if ids else 1
    slug = re.sub(r"[^a-z0-9]+", "-", a.title.lower()).strip("-")[:40].rstrip("-")
    if not slug:
        sys.exit("worklog: title yields an empty slug")
    date = time.strftime("%Y-%m-%d", time.gmtime())
    path, content = adr.scaffold(
        a.title, nid, slug, date, status=a.status,
        deciders=a.deciders.split(",") if a.deciders else None,
        tags=a.tags.split(",") if a.tags else None,
        supersedes=a.supersedes)
    if os.path.exists(path):
        sys.exit(f"worklog: {path} exists")
    if a.supersedes is not None:
        old = ids.get(a.supersedes)
        if not old:
            sys.exit(f"worklog: no ADR {a.supersedes:04d} to supersede")
        adr.mark_superseded(old, nid)
    os.makedirs(adr.ADR_DIR, exist_ok=True)
    with open(path, "w", encoding="utf-8") as fh:
        fh.write(content)
    key = f"adr/{nid:04d}-{slug}"
    _register_published(key, path, f"ADR-{nid:04d}-{slug}")
    print(path)


def cmd_adr_list(a):
    import adr
    rows = []
    for path in adr.adr_files():
        with open(path, encoding="utf-8") as fh:
            try:
                meta, _ = adr.parse_front_matter(fh.read())
            except ValueError:
                continue  # adr check names it; the listing stays best-effort
        rows.append(meta)
    for m in sorted(rows, key=lambda m: m.get("id") or 0):
        print(f"{m.get('id') or 0:04d}  {m.get('status','?'):10}  "
              f"{m.get('title','')}")


def cmd_adr_check(a):
    import adr
    problems = adr.check_all()
    for pr in problems:
        print(pr)
    if problems:
        sys.exit(1)
    print(f"adr: {len(adr.adr_files())} records ok")


def cmd_compact(a):
    if not a.yes:
        sys.exit("worklog: compaction runs in CI on main (spec §7); "
                 "pass --yes to run anyway")
    import compact
    wm = compact.compact()
    print(f"compacted through {wm}" if wm else "nothing to compact")


def _rfc3339(ms):
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(ms / 1000))


def _date_ms(s):
    import calendar
    try:
        return calendar.timegm(time.strptime(s, "%Y-%m-%d")) * 1000
    except ValueError:
        sys.exit(f"worklog: bad date {s!r}; want YYYY-MM-DD")


def _git_commits(date):
    """Commit subjects for one day. Best-effort fact (spec 13.3): outside a
    git repo, or on any git failure, the answer is simply []."""
    import subprocess
    try:
        p = subprocess.run(
            ["git", "log", f"--since={date}T00:00:00",
             f"--until={date}T23:59:59", "--format=%s"],
            capture_output=True, text=True)
    except OSError:
        return []
    return [l for l in p.stdout.splitlines() if l.strip()] \
        if p.returncode == 0 else []


def _status_window(kind, now_ms, since=None, until=None):
    """Window edges in ms (WORKLOG-SPEC 13.3). daily: since the last daily
    report, else the 24h before the newest event; weekly: 7 days ending now;
    timecard: --since/--until UTC dates inclusive (default: last 7 days)."""
    import calendar, glob, re
    import render_roadmap
    if kind == "timecard":
        today = time.strftime("%Y-%m-%d", time.gmtime(now_ms / 1000))
        week_ago = time.strftime("%Y-%m-%d",
                                 time.gmtime(now_ms / 1000 - 7 * 86400))
        return (_date_ms(since or week_ago),
                _date_ms(until or today) + 86400000 - 1)
    if kind == "weekly":
        return now_ms - 7 * 86400000, now_ms
    dates = [m.group(1) for f in glob.glob("docs/status/*-daily.md")
             if (m := re.match(r"(\d{4}-\d{2}-\d{2})-daily\.md$",
                               os.path.basename(f)))]
    if dates:
        # ponytail: the filename carries only a date, so the window opens at
        # that midnight UTC; parse the report's front matter if that's ever
        # too coarse.
        return calendar.timegm(time.strptime(max(dates), "%Y-%m-%d")) * 1000, now_ms
    top = render_roadmap.max_ev(PATHS)
    start = ulid.timestamp_ms(top) if top else now_ms
    return start - 86400000, now_ms


def _status_facts(kind, now_ms, since=None, until=None):
    """Deterministic facts for a status report: a fold plus a raw-event pass
    to decide what happened inside the window (an event is in-window when its
    `ev` ULID timestamp is). The prose is the skill's job, not ours."""
    import render_roadmap
    lo, hi = _status_window(kind, now_ms, since, until)
    r = fold(PATHS)
    items = r.items
    raw = dedupe_and_sort(read_lines(list(PATHS), FoldResult()), FoldResult())
    per = {}
    for e in raw:
        if e["op"] != "compact":
            per.setdefault(e["item"], []).append(e)

    def in_window(e):
        return lo <= ulid.timestamp_ms(e["ev"]) <= hi

    def title(iid):
        return items.get(iid, {}).get("title", iid[:8])

    def epic_title(iid):
        eid = render_roadmap.root_epic_id(iid, items)
        return items[eid].get("title") if eid else None

    if kind == "timecard":
        # One bucket per UTC day (by event `ev` timestamp), days with no
        # activity omitted, no item IDs — spec 13.3, narrative only.
        days = {}

        def bucket(d):
            return days.setdefault(d, {"date": d, "closed": [], "opened": [],
                                       "commits": []})

        def day_of(e):
            return time.strftime("%Y-%m-%d",
                                 time.gmtime(ulid.timestamp_ms(e["ev"]) / 1000))

        for iid, evs in per.items():
            it = items.get(iid, {})
            for e in evs:
                if not in_window(e):
                    continue
                if e["op"] == "close" and it.get("status") in CLOSED_STATUSES:
                    bucket(day_of(e))["closed"].append(
                        {"title": it.get("title", ""),
                         "resolution": it.get("resolution"),
                         "unplanned": bool(it.get("unplanned"))})
                elif e["op"] == "create":
                    dd = it.get("discovered_during")
                    bucket(day_of(e))["opened"].append(
                        {"title": it.get("title", ""),
                         "unplanned": bool(it.get("unplanned")),
                         "discovered_during_title": title(dd) if dd else None})
        d_ms = lo   # midnight UTC of --since; stepping a day stays midnight
        while d_ms <= hi:
            date = time.strftime("%Y-%m-%d", time.gmtime(d_ms / 1000))
            subjects = _git_commits(date)
            if subjects:
                bucket(date)["commits"] = subjects
            d_ms += 86400000
        for v in days.values():
            v["closed"].sort(key=lambda x: x["title"])
            v["opened"].sort(key=lambda x: x["title"])
        return {"kind": kind,
                "window": {"from": _rfc3339(lo), "to": _rfc3339(hi)},
                "through": render_roadmap.max_ev(PATHS),
                "days": [days[k] for k in sorted(days)]}

    closed, opened, unplanned = [], [], []
    for iid, evs in per.items():
        it = items.get(iid, {})
        if (it.get("status") in CLOSED_STATUSES
                and any(e["op"] == "close" and in_window(e) for e in evs)):
            closed.append({"id": iid, "title": it.get("title", ""),
                           "status": it.get("status"),
                           "resolution": it.get("resolution"),
                           "unplanned": bool(it.get("unplanned")),
                           "epic": epic_title(iid)})
        if any(e["op"] == "create" and in_window(e) for e in evs):
            opened.append({"id": iid, "title": it.get("title", ""),
                           "type": it.get("level"), "epic": epic_title(iid)})
            if it.get("unplanned"):
                dd = it.get("discovered_during")
                unplanned.append({"id": iid, "title": it.get("title", ""),
                                  "discovered_during": title(dd) if dd else None})

    in_prog, blocked = [], []
    for iid, it in items.items():
        if it.get("status") == "in_progress":
            evs = per.get(iid, [])
            started = next((e for e in evs
                            if (e.get("set") or {}).get("status") == "in_progress"),
                           evs[0] if evs else None)
            age = (round((now_ms - ulid.timestamp_ms(started["ev"])) / 86400000, 1)
                   if started else None)
            in_prog.append({"id": iid, "title": it.get("title", ""),
                            "age_days": age, "epic": epic_title(iid)})
        if it.get("status") in OPEN_STATUSES:
            blockers = [title(d) for d in it.get("depends_on") or []
                        if items.get(d, {}).get("status") not in CLOSED_STATUSES]
            if it.get("status") == "blocked" or blockers:
                blocked.append({"id": iid, "title": it.get("title", ""),
                                "blocked_by": blockers})

    conflicts = [{"id": iid, "title": title(iid), "conflict": c}
                 for iid, c in r.conflicts()]
    facts = {
        "kind": kind,
        "window": {"from": _rfc3339(lo), "to": _rfc3339(hi)},
        "through": render_roadmap.max_ev(PATHS),
        "closed_in_window": sorted(closed, key=lambda x: x["id"]),
        "opened_in_window": sorted(opened, key=lambda x: x["id"]),
        "in_progress": sorted(in_prog, key=lambda x: x["id"]),
        "blocked": sorted(blocked, key=lambda x: x["id"]),
        "unplanned_in_window": sorted(unplanned, key=lambda x: x["id"]),
        "conflicts": conflicts,
    }
    facts["counts"] = {k: len(facts[k]) for k in
                       ("closed_in_window", "opened_in_window", "in_progress",
                        "blocked", "unplanned_in_window", "conflicts")}
    return facts


def cmd_status(a):
    now_ms = int(time.time() * 1000)
    facts = _status_facts(a.kind, now_ms, a.since, a.until)
    if a.emit_facts:
        print(json.dumps(facts, indent=2, sort_keys=True))
        return
    if not (a.write or a.dry_run):
        sys.exit("worklog: pass --emit-facts (facts as JSON) "
                 "or --write (prose on stdin)")
    prose = sys.stdin.read()
    # A timecard is named for the end of its window, not the day it was run.
    date = (facts["window"]["to"][:10] if a.kind == "timecard"
            else time.strftime("%Y-%m-%d", time.gmtime(now_ms / 1000)))
    path = f"docs/status/{date}-{a.kind}.md"
    doc = ("---\n"
           f"kind: {a.kind}\n"
           f"date: {date}\n"
           f"window: {{from: {facts['window']['from']}, "
           f"to: {facts['window']['to']}}}\n"
           f"through: {facts['through'] or 'null'}\n"
           f"generated_at: {_rfc3339(now_ms)}\n"
           "---\n\n" + prose.rstrip("\n") + "\n")
    if a.dry_run:
        sys.stdout.write(doc)
        return
    if os.path.exists(path) and not a.force:
        sys.exit(f"worklog: {path} exists; status reports are frozen "
                 "(invariant 15.9) — corrections go in the next report "
                 "(--force to overwrite)")
    os.makedirs("docs/status", exist_ok=True)
    with open(path, "w", encoding="utf-8") as fh:
        fh.write(doc)
    print(path)


def cmd_sync(a):
    """The dispatcher owns every sync invariant; this just runs it in-process."""
    import sync_dispatch
    argv = []
    if a.dry_run:
        argv.append("--dry-run")
    if a.keys:
        argv += ["--keys", a.keys]
    if a.push_only:
        argv.append("--push-only")
    if a.pull_only:
        argv.append("--pull-only")
    argv += ["--retry-base-delay", str(a.retry_base_delay)]
    sys.exit(sync_dispatch.main(argv))


def _config_system():
    """ticketing.system from .work/config.yml; None if absent or 'none'."""
    try:
        with open(".work/config.yml", encoding="utf-8") as fh:
            lines = fh.read().splitlines()
    except OSError:
        return None
    in_block = False
    for line in lines:
        if line.startswith("ticketing:"):
            in_block = True
            continue
        if in_block:
            if line and not line[0].isspace():
                break
            s = line.strip()
            if s.startswith("system:"):
                v = s.split(":", 1)[1].split("#", 1)[0].strip().strip("\"'")
                return v if v and v != "none" else None
    return None


def _fake_round_trip(sync_dispatch, path, caps):
    """Push/pull round-trip against the FAKE's semantics, in a throwaway
    state file. Only ever run when the target IS the fake."""
    import subprocess, tempfile
    with tempfile.TemporaryDirectory(prefix="adapter-check-") as td:
        env = dict(os.environ, WORKLOG_FAKE_STATE=os.path.join(td, "state.json"))
        iid = ulid.new()
        payload = json.dumps({
            "op": "create", "key": None,
            "marker": caps["marker"]["template"].replace("{ulid}", iid),
            "item": {"id": iid, "type": "task", "title": "adapter check",
                     "status": "todo"}})
        p = subprocess.run([path, "push"], input=payload, env=env,
                           capture_output=True, text=True)
        if p.returncode != 0:
            raise sync_dispatch.ContractError(
                "push exited %d: %s" % (p.returncode, p.stderr.strip()))
        resp = json.loads(p.stdout)
        for field in ("key", "url", "rev"):
            if not resp.get(field):
                raise sync_dispatch.ContractError(
                    "push_response.%s: missing or empty" % field)
        p = subprocess.run([path, "pull"], env=env,
                           capture_output=True, text=True)
        if p.returncode != 0:
            raise sync_dispatch.ContractError("pull exited %d" % p.returncode)
        lines = [json.loads(l) for l in p.stdout.splitlines() if l.strip()]
        if not any(l.get("id") == iid for l in lines):
            raise sync_dispatch.ContractError(
                "pull_line.id: pushed marker did not round-trip")


ADAPTER_INIT_GUIDANCE = """\
worklog adapter init: adapters are adapted from the worked example, never
written from a blank file.
  1. Read adapters/README.md (authoring rules and the verb table).
  2. Adapt adapters/github/adapter to your tracker's CLI — this is the
     model's job: ask it to generate an adapter for ticketing.system,
     starting from the github example.
  3. Validate it: bin/worklog adapter check adapters/<system>/adapter
Nothing activates until `adapter check` is green."""


def cmd_adapter(a):
    import sync_dispatch
    if a.action == "init":
        print(ADAPTER_INIT_GUIDANCE)
        return
    # check
    path = a.path or os.environ.get("WORKLOG_TICKET_ADAPTER")
    if not path:
        system = _config_system() or "fake"
        path = os.path.join("adapters", system, "adapter")
        if not os.path.exists(path):
            path = os.path.join("adapters", "fake", "adapter")
    if not os.path.exists(path):
        sys.exit(f"worklog: adapter not found: {path}")
    path = os.path.abspath(path)
    d = sync_dispatch.Dispatcher(path, retry_base_delay=0, dry_run=True)
    try:
        caps = d.capabilities()
        if os.path.basename(os.path.dirname(path)) == "fake":
            _fake_round_trip(sync_dispatch, path, caps)
        else:
            print("live verbs not exercised (--dry-run shape check only)")
    except sync_dispatch.ContractError as e:
        sys.exit(f"worklog: adapter contract violation: {e}")
    state = {}
    try:
        with open(".work/sync-state.json", encoding="utf-8") as fh:
            state = json.load(fh)
    except (FileNotFoundError, json.JSONDecodeError):
        pass
    state["adapter_path"] = path
    os.makedirs(".work", exist_ok=True)
    with open(".work/sync-state.json", "w", encoding="utf-8") as fh:
        json.dump(state, fh, indent=2, sort_keys=True)
        fh.write("\n")
    print(f"adapter ok: {caps['system']} ({path})")
    print(f"export WORKLOG_TICKET_ADAPTER={path}")


