#!/usr/bin/env python3
"""GitHub adapter for worklog ticket-sync.

Dumb translator only (plan 2026-07-18-typed-adapter-contract §6): maps
canonical items to `gh` calls and back. All sync invariants — hashing,
dedupe, scope, conflicts, create-vs-update — live in the dispatcher.
Stdout is data; everything else goes to stderr. Exit codes per §3.6.
"""
import json
import os
import re
import subprocess
import sys

MARKER = re.compile(r"worklog:([0-9A-Z]{26})")

CAPABILITIES = {
    "system": "github",
    "supports": ["push", "pull", "get", "close"],
    # Keyed by LEVEL (worklog-spec §5.4 v1.7) — a bug is a kind, not a level.
    "types": {"epic": None, "story": "Issue", "task": "Issue",
              "subtask": "Issue"},
    # Informational: how each kind lands on the platform.
    "kinds": {"feature": "default", "bug": "bug label", "ops": "label",
              "triage": "needs-triage label"},
    "marker": {"style": "html_comment", "template": "<!-- worklog:{ulid} -->"},
    "fields": {"parent": "body-line", "depends_on": "unsupported",
               "assignee": "assignee", "milestone": "milestone"},
    "max_title": 256,
}

# Deprecated `type` alias -> (level, kind); the fold normalizes, we tolerate.
LEGACY_TYPE = {"epic": ("epic", "feature"), "story": ("story", "feature"),
               "task": ("task", "feature"), "subtask": ("subtask", "feature"),
               "bug": ("task", "bug")}


def log(msg):
    print(msg, file=sys.stderr)


def die(code, msg):
    log(msg)
    sys.exit(code)


def classify(stderr):
    """Map gh failure text to contract exit codes (§3.6)."""
    e = (stderr or "").lower()
    if any(s in e for s in ("bad credentials", "gh auth login", "authentication",
                            "unauthorized", "401")):
        return 2
    if any(s in e for s in ("not found", "404", "could not resolve")):
        return 3
    if any(s in e for s in ("rate limit", "abuse", "timed out", "timeout",
                            "try again later")):
        return 4
    return 1


def gh(args):
    p = subprocess.run(["gh", *args], capture_output=True, text=True)
    if p.stderr:
        sys.stderr.write(p.stderr)
    if p.returncode != 0:
        sys.exit(classify(p.stderr))
    return p.stdout


def target_repo():
    r = os.environ.get("WORKLOG_TICKET_PROJECT")
    if r:
        return r
    return gh(["repo", "view", "--json", "nameWithOwner",
               "-q", ".nameWithOwner"]).strip()


def ensure_label(repo, name):
    # ponytail: best-effort `gh label create || true`; existing label is fine
    p = subprocess.run(["gh", "label", "create", name, "-R", repo],
                       capture_output=True, text=True)
    if p.returncode != 0:
        log(f"label {name}: {p.stderr.strip()}")


def issue_rev(repo, key):
    out = gh(["issue", "view", str(key), "-R", repo, "--json", "updatedAt"])
    return json.loads(out)["updatedAt"]


def taxonomy(item):
    """(level, kind) from the item; deprecated `type` alias tolerated."""
    level, kind = item.get("level"), item.get("kind")
    if not level and item.get("type"):
        lv, kd = LEGACY_TYPE.get(item["type"], (item["type"], None))
        level, kind = lv, kind or kd
    return level, kind


def item_labels(item):
    labels = ["worklog"]
    level, kind = taxonomy(item)
    if level:
        labels.append(f"level:{level}")
    if kind:
        labels.append(f"kind:{kind}")
    if kind == "bug":
        labels.append("bug")  # the platform's native bug label too
    if item.get("priority"):
        labels.append(item["priority"])
    return labels


def set_milestone(repo, key, milestone):
    # ponytail: best-effort translation — create the milestone if absent,
    # attach it; every failure goes to stderr, none is fatal.
    p = subprocess.run(["gh", "api", f"repos/{repo}/milestones",
                        "--jq", ".[].title"], capture_output=True, text=True)
    titles = p.stdout.splitlines() if p.returncode == 0 else []
    if milestone not in titles:
        c = subprocess.run(["gh", "api", f"repos/{repo}/milestones",
                            "-f", f"title={milestone}"],
                           capture_output=True, text=True)
        if c.returncode != 0:
            log(f"milestone create {milestone}: {c.stderr.strip()}")
    e = subprocess.run(["gh", "issue", "edit", str(key), "-R", repo,
                        "--milestone", milestone],
                       capture_output=True, text=True)
    if e.returncode != 0:
        log(f"milestone {milestone} on #{key}: {e.stderr.strip()}")


def build_body(marker, item):
    parts = []
    if marker:
        parts.append(marker)
    if item.get("body"):
        parts.append(item["body"].rstrip())
    if item.get("id"):
        parts.append(f"worklog id `{item['id']}`")
    return "\n\n".join(parts)


def to_line(issue):
    body = issue.get("body") or ""
    ids = MARKER.findall(body)
    line = {
        "external": {"key": str(issue["number"]), "rev": issue["updatedAt"]},
        "id": ids[0] if ids else None,
        "title": issue.get("title"),
    }
    if (issue.get("state") or "").upper() == "CLOSED":
        line["status"] = "done"
    legacy = None
    for lab in issue.get("labels") or []:
        name = lab.get("name") if isinstance(lab, dict) else lab
        if name in ("P0", "P1", "P2", "P3"):
            line["priority"] = name
        elif name.startswith("level:"):
            line["level"] = name[len("level:"):]
        elif name.startswith("kind:"):
            line["kind"] = name[len("kind:"):]
        elif name.startswith("type:"):
            legacy = name[len("type:"):]
    if legacy and "level" not in line:
        # Ticket pushed under the pre-1.7 type:* scheme still round-trips.
        level, kind = LEGACY_TYPE.get(legacy, (legacy, None))
        line["level"] = level
        if kind and "kind" not in line:
            line["kind"] = kind
    ms = issue.get("milestone")
    if isinstance(ms, dict) and ms.get("title"):
        line["milestone"] = ms["title"]
    return line


ISSUE_JSON = "number,title,body,labels,state,milestone,updatedAt"


def fetch_issue(repo, key):
    out = gh(["issue", "view", str(key), "-R", repo, "--json", ISSUE_JSON])
    return json.loads(out)


def cmd_capabilities():
    print(json.dumps(CAPABILITIES))


def cmd_push():
    repo = target_repo()
    req = json.load(sys.stdin)
    op, key, marker = req.get("op"), req.get("key"), req.get("marker")
    item = req.get("item") or {}
    labels = item_labels(item)
    for lab in labels:
        ensure_label(repo, lab)

    if op == "create":
        args = ["issue", "create", "-R", repo,
                "--title", item.get("title") or "(untitled)",
                "--body", build_body(marker, item)]
        for lab in labels:
            args += ["--label", lab]
        url = gh(args).strip().splitlines()[-1]
        key = url.rstrip("/").rsplit("/", 1)[-1]
    elif op == "update":
        if key is None:
            die(1, "push op=update with null key: dispatcher bug")
        args = ["issue", "edit", str(key), "-R", repo,
                # body carries the marker + readable description (§13.4);
                # without it, body edits authored locally never reach the
                # ticket and update-synced issues stay marker-only.
                "--body", build_body(marker, item)]
        if item.get("title"):
            args += ["--title", item["title"]]
        for lab in labels:
            args += ["--add-label", lab]
        gh(args)
        url = f"https://github.com/{repo}/issues/{key}"
    else:
        die(1, f"unknown push op: {op!r}")

    if item.get("milestone"):
        set_milestone(repo, key, item["milestone"])

    print(json.dumps({"key": str(key), "url": url,
                      "rev": issue_rev(repo, key), "hash": None}))


def cmd_pull(argv):
    repo = target_repo()
    since = keys = None
    it = iter(argv)
    for a in it:
        if a == "--since":
            since = next(it, None)
        elif a == "--keys":
            keys = next(it, None)
    if keys:
        for k in keys.split(","):
            print(json.dumps(to_line(fetch_issue(repo, k.strip()))))
        return
    if not since:
        die(1, "pull requires --since <iso> or --keys")
    out = gh(["issue", "list", "-R", repo, "--state", "all",
              "--json", ISSUE_JSON,
              "-S", f"worklog: in:body updated:>{since}"])
    for issue in json.loads(out):
        print(json.dumps(to_line(issue)))


def cmd_get(key):
    print(json.dumps(to_line(fetch_issue(target_repo(), key))))


def cmd_close(key, resolution):
    repo = target_repo()
    gh(["issue", "close", str(key), "-R", repo, "-c", resolution])
    print(json.dumps({"key": str(key), "rev": issue_rev(repo, key)}))


def main(argv):
    system = os.environ.get("WORKLOG_TICKET_SYSTEM")
    if system and system != "github":
        log(f"warning: WORKLOG_TICKET_SYSTEM={system!r}, this adapter is github")
    if not argv:
        die(1, "usage: adapter capabilities|push|pull|get|close")
    verb, rest = argv[0], argv[1:]
    if verb == "capabilities":
        cmd_capabilities()
    elif verb == "push":
        cmd_push()
    elif verb == "pull":
        cmd_pull(rest)
    elif verb == "get" and rest:
        cmd_get(rest[0])
    elif verb == "close" and len(rest) >= 2:
        cmd_close(rest[0], rest[1])
    else:
        die(1, f"bad invocation: {argv}")


if __name__ == "__main__":
    main(sys.argv[1:])
