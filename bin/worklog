#!/usr/bin/env python3
"""
worklog -- CLI entry point. WORKLOG-SPEC section 12.

Implemented: add, update, close, link, show, list, fold, plan-capture,
             roadmap-render, roadmap-snapshot, wiki-add, compact,
             status (daily|weekly|timecard).
Stubbed:     sync.

Nothing else in the repo may write to .work/*.jsonl (invariant 15.4).
"""
import argparse, json, os, sys, time
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import ulid
from fold import (fold, FoldResult, read_lines, dedupe_and_sort,
                  OPEN_STATUSES, CLOSED_STATUSES)

LOG = ".work/todo.jsonl"
PATHS = (".work/todo.jsonl", ".work/done.jsonl")
MAX_BODY = 2048  # derived from PIPE_BUF (section 8.3). Not a setting.
VERSION = "0.4.0"  # kept in step with plugin/.claude-plugin/plugin.json by tests/test_plugin.py


def append(event):
    """The only writer. Single O_APPEND write, always newline-terminated.

    Also self-heals a missing trailing newline on the existing file (a hand
    edit the hook hasn't caught yet): appending without the repair would fuse
    two events into one unparseable line and lose both (section 8.2).
    """
    if len(event.get("set", {}).get("body", "")) > MAX_BODY:
        sys.exit(f"worklog: body exceeds {MAX_BODY}B; put prose in the plan doc")
    line = json.dumps(event, separators=(",", ":"), sort_keys=True) + "\n"
    fd = os.open(LOG, os.O_WRONLY | os.O_APPEND | os.O_CREAT, 0o644)
    try:
        if os.fstat(fd).st_size:
            rfd = os.open(LOG, os.O_RDONLY)
            try:
                os.lseek(rfd, -1, os.SEEK_END)
                if os.read(rfd, 1) != b"\n":
                    line = "\n" + line
            finally:
                os.close(rfd)
        os.write(fd, line.encode())   # atomic under PIPE_BUF
    finally:
        os.close(fd)
    return event


def base(item, op, actor):
    return {"ev": ulid.new(), "ts": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "actor": actor, "item": item, "op": op}


def cmd_add(a):
    if a.unplanned and not a.discovered_during:
        sys.exit("worklog: --unplanned requires --discovered-during (section 5.4)")
    item = ulid.new()
    ev = base(item, "create", a.actor)
    ev["set"] = {k: v for k, v in {
        "type": a.type, "title": a.title, "status": "todo", "priority": a.priority,
        "parent": a.parent, "plan": a.plan,
        "unplanned": True if a.unplanned else None,
        "discovered_during": a.discovered_during,
    }.items() if v is not None}
    if a.labels:
        ev["set"]["labels"] = a.labels.split(",")
    append(ev)
    print(item)


def cmd_update(a):
    ev = base(a.item, "update", a.actor)
    ev["set"] = {k: v for k, v in
                 {"status": a.status, "priority": a.priority, "title": a.title}.items()
                 if v is not None}
    if a.add_label:
        ev["add"] = {"labels": a.add_label.split(",")}
    if a.del_label:
        ev["del"] = {"labels": a.del_label.split(",")}
    if not (ev.get("set") or ev.get("add") or ev.get("del")):
        sys.exit("worklog: nothing to update")
    append(ev)


def cmd_close(a):
    ev = base(a.item, "close", a.actor)
    ev["set"] = {"status": a.status}
    if a.resolution:
        ev["set"]["resolution"] = a.resolution
    append(ev)


def cmd_link(a):
    ev = base(a.item, "link", a.actor)
    ev["set"] = {"external": {k: v for k, v in {
        "system": a.system, "key": a.key, "url": a.url, "rev": a.rev,
        "hash": a.hash,
        "synced_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    }.items() if v is not None}}
    append(ev)


PUBLISHED = ".work/published.json"


def cmd_wiki_add(a):
    """Register a file in the wiki publish set. published.json is a plain JSON
    map (spec 9.2), not an event log, so direct load/dump is allowed here."""
    if not os.path.exists(a.file):
        sys.exit(f"worklog: {a.file} not found")
    published = {}
    if os.path.exists(PUBLISHED):
        with open(PUBLISHED, encoding="utf-8") as fh:
            published = json.load(fh)
    # Preserve url/rev/source_hash on re-register: wiping them would make the
    # next publish create a duplicate page (spec 9.2).
    entry = published.setdefault(a.key, {"url": None, "rev": None,
                                         "source_hash": None})
    entry["source"] = a.file
    entry["title"] = a.title
    os.makedirs(os.path.dirname(PUBLISHED), exist_ok=True)
    with open(PUBLISHED, "w", encoding="utf-8") as fh:
        json.dump(published, fh, indent=2, sort_keys=True)
        fh.write("\n")
    print(a.key)


def cmd_list(a):
    r = fold([LOG, ".work/done.jsonl"])
    items = r.open_items() if not a.all else list(r.items.values())
    for i in sorted(items, key=lambda x: (x.get("priority", "P9"), x["id"])):
        ext = i.get("external", {}).get("key", "-")
        print(f"{i['id'][:8]}  {i.get('priority','--'):3}  {i.get('status','?'):12} "
              f"{ext:10} {i.get('title','')}")
    if r.conflicts():
        print(f"\n{len(r.conflicts())} conflict(s) need attention: worklog show <id>",
              file=sys.stderr)


def cmd_show(a):
    r = fold([LOG, ".work/done.jsonl"])
    match = [i for k, i in r.items.items() if k.startswith(a.item)]
    if not match:
        sys.exit(f"worklog: no item matching {a.item}")
    print(json.dumps(match[0], indent=2))


def cmd_fold(a):
    r = fold([LOG, ".work/done.jsonl"])
    print(json.dumps(sorted(r.items.values(), key=lambda i: i["id"]), indent=2))


def cmd_roadmap_render(a):
    import render_roadmap
    md = render_roadmap.render()
    os.makedirs("docs", exist_ok=True)
    with open("docs/roadmap.md", "w", encoding="utf-8") as fh:
        fh.write(md)
    print("docs/roadmap.md")


def cmd_roadmap_snapshot(a):
    import shutil
    if not os.path.exists("docs/roadmap.md"):
        sys.exit("worklog: docs/roadmap.md not found; run roadmap-render first")
    date = time.strftime("%Y-%m-%d", time.gmtime())
    name = f"{date}_{a.name}" if a.name else date
    path = f"docs/roadmap/{name}.md"
    if os.path.exists(path):
        sys.exit(f"worklog: {path} exists; snapshots are frozen "
                 "— pick a new --name")
    os.makedirs("docs/roadmap", exist_ok=True)
    shutil.copyfile("docs/roadmap.md", path)
    print(path)


def cmd_plan_capture(a):
    import plan_capture
    draft = open(a.file, encoding="utf-8").read() if a.file else sys.stdin.read()
    tasks = plan_capture.parse_tasks(draft)
    if not tasks:
        sys.exit("worklog: no '- [ ]' tasks found under a '## Tasks' heading")
    date = time.strftime("%Y-%m-%d", time.gmtime())
    path = f"docs/plans/{date}-{a.slug}.md"
    if os.path.exists(path):
        sys.exit(f"worklog: {path} exists; plans are never rewritten "
                 "(invariant 15.8) — pick a new slug to supersede")

    epic_id = ulid.new()
    ev = base(epic_id, "create", a.actor)
    ev["set"] = {"type": "epic", "title": a.title, "status": "todo",
                 "priority": a.priority, "plan": path}
    append(ev)

    item_ids, last_task = [], epic_id
    for t in tasks:
        iid = ulid.new()
        ev = base(iid, "create", a.actor)
        ev["set"] = {"type": "subtask" if t["subtask"] else "task",
                     "title": t["title"], "status": "todo",
                     "priority": t["priority"],
                     "parent": last_task if t["subtask"] else epic_id,
                     "plan": path}
        append(ev)
        item_ids.append(iid)
        if not t["subtask"]:
            last_task = iid

    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as fh:
        fh.write(plan_capture.front_matter(date, a.slug, a.title, epic_id, item_ids))
        fh.write(draft)
    print(path)
    print(epic_id)


def cmd_compact(a):
    if not a.yes:
        sys.exit("worklog: compaction runs in CI on main (spec §7); "
                 "pass --yes to run anyway")
    import compact
    wm = compact.compact()
    print(f"compacted through {wm}" if wm else "nothing to compact")


def _rfc3339(ms):
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(ms / 1000))


def _date_ms(s):
    import calendar
    try:
        return calendar.timegm(time.strptime(s, "%Y-%m-%d")) * 1000
    except ValueError:
        sys.exit(f"worklog: bad date {s!r}; want YYYY-MM-DD")


def _git_commits(date):
    """Commit subjects for one day. Best-effort fact (spec 13.3): outside a
    git repo, or on any git failure, the answer is simply []."""
    import subprocess
    try:
        p = subprocess.run(
            ["git", "log", f"--since={date}T00:00:00",
             f"--until={date}T23:59:59", "--format=%s"],
            capture_output=True, text=True)
    except OSError:
        return []
    return [l for l in p.stdout.splitlines() if l.strip()] \
        if p.returncode == 0 else []


def _status_window(kind, now_ms, since=None, until=None):
    """Window edges in ms (WORKLOG-SPEC 13.3). daily: since the last daily
    report, else the 24h before the newest event; weekly: 7 days ending now;
    timecard: --since/--until UTC dates inclusive (default: last 7 days)."""
    import calendar, glob, re
    import render_roadmap
    if kind == "timecard":
        today = time.strftime("%Y-%m-%d", time.gmtime(now_ms / 1000))
        week_ago = time.strftime("%Y-%m-%d",
                                 time.gmtime(now_ms / 1000 - 7 * 86400))
        return (_date_ms(since or week_ago),
                _date_ms(until or today) + 86400000 - 1)
    if kind == "weekly":
        return now_ms - 7 * 86400000, now_ms
    dates = [m.group(1) for f in glob.glob("docs/status/*-daily.md")
             if (m := re.match(r"(\d{4}-\d{2}-\d{2})-daily\.md$",
                               os.path.basename(f)))]
    if dates:
        # ponytail: the filename carries only a date, so the window opens at
        # that midnight UTC; parse the report's front matter if that's ever
        # too coarse.
        return calendar.timegm(time.strptime(max(dates), "%Y-%m-%d")) * 1000, now_ms
    top = render_roadmap.max_ev(PATHS)
    start = ulid.timestamp_ms(top) if top else now_ms
    return start - 86400000, now_ms


def _status_facts(kind, now_ms, since=None, until=None):
    """Deterministic facts for a status report: a fold plus a raw-event pass
    to decide what happened inside the window (an event is in-window when its
    `ev` ULID timestamp is). The prose is the skill's job, not ours."""
    import render_roadmap
    lo, hi = _status_window(kind, now_ms, since, until)
    r = fold(PATHS)
    items = r.items
    raw = dedupe_and_sort(read_lines(list(PATHS), FoldResult()), FoldResult())
    per = {}
    for e in raw:
        if e["op"] != "compact":
            per.setdefault(e["item"], []).append(e)

    def in_window(e):
        return lo <= ulid.timestamp_ms(e["ev"]) <= hi

    def title(iid):
        return items.get(iid, {}).get("title", iid[:8])

    def epic_title(iid):
        eid = render_roadmap.root_epic_id(iid, items)
        return items[eid].get("title") if eid else None

    if kind == "timecard":
        # One bucket per UTC day (by event `ev` timestamp), days with no
        # activity omitted, no item IDs — spec 13.3, narrative only.
        days = {}

        def bucket(d):
            return days.setdefault(d, {"date": d, "closed": [], "opened": [],
                                       "commits": []})

        def day_of(e):
            return time.strftime("%Y-%m-%d",
                                 time.gmtime(ulid.timestamp_ms(e["ev"]) / 1000))

        for iid, evs in per.items():
            it = items.get(iid, {})
            for e in evs:
                if not in_window(e):
                    continue
                if e["op"] == "close" and it.get("status") in CLOSED_STATUSES:
                    bucket(day_of(e))["closed"].append(
                        {"title": it.get("title", ""),
                         "resolution": it.get("resolution"),
                         "unplanned": bool(it.get("unplanned"))})
                elif e["op"] == "create":
                    dd = it.get("discovered_during")
                    bucket(day_of(e))["opened"].append(
                        {"title": it.get("title", ""),
                         "unplanned": bool(it.get("unplanned")),
                         "discovered_during_title": title(dd) if dd else None})
        d_ms = lo   # midnight UTC of --since; stepping a day stays midnight
        while d_ms <= hi:
            date = time.strftime("%Y-%m-%d", time.gmtime(d_ms / 1000))
            subjects = _git_commits(date)
            if subjects:
                bucket(date)["commits"] = subjects
            d_ms += 86400000
        for v in days.values():
            v["closed"].sort(key=lambda x: x["title"])
            v["opened"].sort(key=lambda x: x["title"])
        return {"kind": kind,
                "window": {"from": _rfc3339(lo), "to": _rfc3339(hi)},
                "through": render_roadmap.max_ev(PATHS),
                "days": [days[k] for k in sorted(days)]}

    closed, opened, unplanned = [], [], []
    for iid, evs in per.items():
        it = items.get(iid, {})
        if (it.get("status") in CLOSED_STATUSES
                and any(e["op"] == "close" and in_window(e) for e in evs)):
            closed.append({"id": iid, "title": it.get("title", ""),
                           "status": it.get("status"),
                           "resolution": it.get("resolution"),
                           "unplanned": bool(it.get("unplanned")),
                           "epic": epic_title(iid)})
        if any(e["op"] == "create" and in_window(e) for e in evs):
            opened.append({"id": iid, "title": it.get("title", ""),
                           "type": it.get("type"), "epic": epic_title(iid)})
            if it.get("unplanned"):
                dd = it.get("discovered_during")
                unplanned.append({"id": iid, "title": it.get("title", ""),
                                  "discovered_during": title(dd) if dd else None})

    in_prog, blocked = [], []
    for iid, it in items.items():
        if it.get("status") == "in_progress":
            evs = per.get(iid, [])
            started = next((e for e in evs
                            if (e.get("set") or {}).get("status") == "in_progress"),
                           evs[0] if evs else None)
            age = (round((now_ms - ulid.timestamp_ms(started["ev"])) / 86400000, 1)
                   if started else None)
            in_prog.append({"id": iid, "title": it.get("title", ""),
                            "age_days": age, "epic": epic_title(iid)})
        if it.get("status") in OPEN_STATUSES:
            blockers = [title(d) for d in it.get("depends_on") or []
                        if items.get(d, {}).get("status") not in CLOSED_STATUSES]
            if it.get("status") == "blocked" or blockers:
                blocked.append({"id": iid, "title": it.get("title", ""),
                                "blocked_by": blockers})

    conflicts = [{"id": iid, "title": title(iid), "conflict": c}
                 for iid, c in r.conflicts()]
    facts = {
        "kind": kind,
        "window": {"from": _rfc3339(lo), "to": _rfc3339(hi)},
        "through": render_roadmap.max_ev(PATHS),
        "closed_in_window": sorted(closed, key=lambda x: x["id"]),
        "opened_in_window": sorted(opened, key=lambda x: x["id"]),
        "in_progress": sorted(in_prog, key=lambda x: x["id"]),
        "blocked": sorted(blocked, key=lambda x: x["id"]),
        "unplanned_in_window": sorted(unplanned, key=lambda x: x["id"]),
        "conflicts": conflicts,
    }
    facts["counts"] = {k: len(facts[k]) for k in
                       ("closed_in_window", "opened_in_window", "in_progress",
                        "blocked", "unplanned_in_window", "conflicts")}
    return facts


def cmd_status(a):
    now_ms = int(time.time() * 1000)
    facts = _status_facts(a.kind, now_ms, a.since, a.until)
    if a.emit_facts:
        print(json.dumps(facts, indent=2, sort_keys=True))
        return
    if not (a.write or a.dry_run):
        sys.exit("worklog: pass --emit-facts (facts as JSON) "
                 "or --write (prose on stdin)")
    prose = sys.stdin.read()
    # A timecard is named for the end of its window, not the day it was run.
    date = (facts["window"]["to"][:10] if a.kind == "timecard"
            else time.strftime("%Y-%m-%d", time.gmtime(now_ms / 1000)))
    path = f"docs/status/{date}-{a.kind}.md"
    doc = ("---\n"
           f"kind: {a.kind}\n"
           f"date: {date}\n"
           f"window: {{from: {facts['window']['from']}, "
           f"to: {facts['window']['to']}}}\n"
           f"through: {facts['through'] or 'null'}\n"
           f"generated_at: {_rfc3339(now_ms)}\n"
           "---\n\n" + prose.rstrip("\n") + "\n")
    if a.dry_run:
        sys.stdout.write(doc)
        return
    if os.path.exists(path) and not a.force:
        sys.exit(f"worklog: {path} exists; status reports are frozen "
                 "(invariant 15.9) — corrections go in the next report "
                 "(--force to overwrite)")
    os.makedirs("docs/status", exist_ok=True)
    with open(path, "w", encoding="utf-8") as fh:
        fh.write(doc)
    print(path)


def stub(name):
    def f(a):
        sys.exit(f"worklog: `{name}` not implemented yet (see WORKLOG-SPEC section 18)")
    return f


p = argparse.ArgumentParser(prog="worklog")
p.add_argument("--actor", default=os.environ.get("USER", "unknown"))
p.add_argument("--version", action="version", version=f"worklog {VERSION}")
sub = p.add_subparsers(dest="cmd", required=True)

a = sub.add_parser("add"); a.set_defaults(fn=cmd_add)
a.add_argument("title")
a.add_argument("--type", default="task",
               choices=["epic", "story", "task", "subtask", "bug"])
a.add_argument("--priority", default="P2", choices=["P0", "P1", "P2", "P3"])
a.add_argument("--parent"); a.add_argument("--plan"); a.add_argument("--labels")
a.add_argument("--unplanned", action="store_true")
a.add_argument("--discovered-during", dest="discovered_during")

u = sub.add_parser("update"); u.set_defaults(fn=cmd_update)
u.add_argument("item")
u.add_argument("--status", choices=["todo", "in_progress", "blocked"])
u.add_argument("--priority", choices=["P0", "P1", "P2", "P3"])
u.add_argument("--title")
u.add_argument("--add-label", dest="add_label")
u.add_argument("--del-label", dest="del_label")

c = sub.add_parser("close"); c.set_defaults(fn=cmd_close)
c.add_argument("item")
c.add_argument("--status", default="done", choices=["done", "cancelled"])
c.add_argument("--resolution")

lk = sub.add_parser("link"); lk.set_defaults(fn=cmd_link)
lk.add_argument("item")
lk.add_argument("--system", required=True)
lk.add_argument("--key", required=True)
lk.add_argument("--url"); lk.add_argument("--rev"); lk.add_argument("--hash")

wa = sub.add_parser("wiki-add"); wa.set_defaults(fn=cmd_wiki_add)
wa.add_argument("file")
wa.add_argument("--key", required=True)
wa.add_argument("--title", required=True)

l = sub.add_parser("list"); l.set_defaults(fn=cmd_list); l.add_argument("--all", action="store_true")
s = sub.add_parser("show"); s.set_defaults(fn=cmd_show); s.add_argument("item")
sub.add_parser("fold").set_defaults(fn=cmd_fold)

pc = sub.add_parser("plan-capture"); pc.set_defaults(fn=cmd_plan_capture)
pc.add_argument("--slug", required=True)
pc.add_argument("--title", required=True)
pc.add_argument("--file")
pc.add_argument("--priority", default="P1", choices=["P0", "P1", "P2", "P3"])

sub.add_parser("roadmap-render").set_defaults(fn=cmd_roadmap_render)
rs = sub.add_parser("roadmap-snapshot"); rs.set_defaults(fn=cmd_roadmap_snapshot)
rs.add_argument("--name")
co = sub.add_parser("compact"); co.set_defaults(fn=cmd_compact)
co.add_argument("--yes", action="store_true")

st = sub.add_parser("status"); st.set_defaults(fn=cmd_status)
st.add_argument("--kind", required=True, choices=["daily", "weekly", "timecard"])
st.add_argument("--emit-facts", dest="emit_facts", action="store_true")
st.add_argument("--since", metavar="YYYY-MM-DD")   # timecard window start
st.add_argument("--until", metavar="YYYY-MM-DD")   # timecard window end
st.add_argument("--write", action="store_true")
st.add_argument("--dry-run", dest="dry_run", action="store_true")
st.add_argument("--force", action="store_true")

sub.add_parser("sync").set_defaults(fn=stub("sync"))

if __name__ == "__main__":
    args = p.parse_args()
    args.fn(args)
